@inherits TestContext
@using gkwebNew.Data
@using gkwebNew.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Logging
@code {
    private void RegisterDb()
    {
        var options = new DbContextOptionsBuilder<ContactDbContext>()
            .UseSqlite("Data Source=:memory:")
            .Options;
        var db = new ContactDbContext(options);
        db.Database.EnsureCreated();
        Services.AddSingleton(db);

        var emailService = new EmailService(
            new ConfigurationBuilder().Build(),
            LoggerFactory.Create(_ => { }).CreateLogger<EmailService>());
        Services.AddSingleton<EmailService>(emailService);
    }

    [Fact]
    public void About_HasPageTitleComponent()
    {
        RegisterDb();
        var cut = Render(@<About />);
        var pageTitle = cut.FindComponent<PageTitle>();
        Assert.NotNull(pageTitle);
    }

    [Fact]
    public void About_RendersCompanyName()
    {
        RegisterDb();
        var cut = Render(@<About />);
        Assert.Contains("GloryKidd Technologies LLC", cut.Markup);
    }

    [Fact]
    public void About_RendersMissionStatement()
    {
        RegisterDb();
        var cut = Render(@<About />);
        Assert.Contains("Our mission is to use workflow processes", cut.Markup);
    }

    [Fact]
    public void About_RendersContactForm()
    {
        RegisterDb();
        var cut = Render(@<About />);
        Assert.Contains("Get In Touch", cut.Markup);
        Assert.NotNull(cut.Find("form"));
    }

    [Fact]
    public void About_HasTwoColumnLayout()
    {
        RegisterDb();
        var cut = Render(@<About />);
        Assert.NotNull(cut.Find(".col-md-4"));
        Assert.NotNull(cut.Find(".col-md-8"));
    }
}
