@page "/admin/contacts"
@layout AdminLayout
@using gkwebNew.Data
@using gkweb.api.types.models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@inject ContactDbContext Db

<PageTitle>Contact Submissions - Admin</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>

<h1 class="visually-hidden">Contact Submissions</h1>

<div class="row mb-3">
    <div class="col">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Contact Submissions</li>
            </ol>
        </nav>
        <h2><i>Contact Submissions</i></h2>
    </div>
    <div class="col-auto">
        <a href="/admin/logout" class="btn btn-outline-secondary btn-sm">Logout</a>
    </div>
</div>

@if (_submissions.Count == 0)
{
    <p class="text-muted">No submissions yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Message</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _submissions)
                {
                    <tr class="@(s.ViewedAt is null ? "table-warning" : "")">
                        <td class="text-nowrap">@s.SubmittedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@s.Name</td>
                        <td>@s.Email</td>
                        <td>@(s.Phone ?? "—")</td>
                        <td class="text-truncate" style="max-width: 250px;">@s.Message</td>
                        <td class="text-nowrap">
                            @if (s.ViewedAt is null)
                            {
                                <span class="badge bg-warning text-dark me-2">New</span>
                            }
                            <a href="/admin/contacts/@s.Id" class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<ContactSubmission> _submissions = [];

    protected override async Task OnInitializedAsync()
    {
        _submissions = await Db.ContactSubmissions
            .OrderByDescending(s => s.SubmittedAt)
            .ToListAsync();
    }
}
